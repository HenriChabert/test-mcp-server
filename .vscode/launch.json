{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run MCP Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "python": "${workspaceFolder}/.venv/bin/python3",
      "env": {
        "API_TOKEN": "dev-secret-token"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "FastMCP Dev (MCP Inspector)",
      "type": "debugpy",
      "request": "launch",
      "module": "fastmcp",
      "args": ["dev", "${workspaceFolder}/main.py"],
      "python": "${workspaceFolder}/.venv/bin/python3",
      "env": {
        "API_TOKEN": "dev-secret-token"
      },
      "console": "integratedTerminal"
    }
  ]
}
